{
  "version": "2.0.0",
  "description": "Task contracts for benchmark runner v2.",
  "tasks": {
    "short_denoise": {
      "domain": ["prostate", "brain"],
      "toolchain": "short",
      "request_type": "denoise",
      "required_modalities": {
        "prostate": { "any_of": ["T2w", "ADC", "DWI_highb"] },
        "brain": { "any_of": ["T1", "T1c", "T2", "FLAIR"] }
      },
      "goal_template": "Task: short_denoise. Requested workflow type: denoise. Domain: {domain}. Case ID: {case_id}. Case root: {case_root}. Execute denoising (NIfTI-only input) and save denoised outputs.",
      "success_criteria": {
        "all": [
          { "type": "tool_success", "tool": "denoise_image_bm3d" }
        ]
      },
      "required_artifacts": [
        { "id": "denoised_nifti", "tool": "denoise_image_bm3d", "data_key": "denoised_nifti", "must_exist": true }
      ],
      "required_stage_success": ["denoise_image_bm3d"],
      "invariants": [
        { "id": "denoised_exists", "type": "path_exists", "tool": "denoise_image_bm3d", "data_key": "denoised_nifti" },
        { "id": "denoised_non_empty", "type": "nifti_nonempty", "tool": "denoise_image_bm3d", "data_key": "denoised_nifti" },
        {
          "id": "denoised_affine_consistent",
          "type": "nifti_affine_match",
          "lhs": { "tool": "denoise_image_bm3d", "data_key": "denoised_nifti" },
          "rhs": { "tool": "denoise_image_bm3d", "data_key": "input_nifti" }
        }
      ],
      "fault_profiles": {
        "token_mutation": {
          "enabled": true,
          "token_pairs": [
            ["@runtime.case_state_path", "@state.path"],
            ["@seq.T2w", "@seq.T2"],
            ["@case.input", "@case.root"]
          ]
        },
        "path_mutation": {
          "enabled": true,
          "modes": ["in_root_semantic", "missing", "scope_escape"]
        },
        "argument_omission": {
          "enabled": true,
          "omit_keys": ["input_nifti"]
        },
        "semantic_swap": {
          "enabled": false
        },
        "space_mismatch": {
          "enabled": false
        },
        "missing_modality": {
          "enabled": true
        },
        "scope_violation": {
          "enabled": true
        }
      }
    },
    "short_superres": {
      "domain": ["prostate", "brain"],
      "toolchain": "short",
      "request_type": "super_resolution",
      "required_modalities": {
        "prostate": { "any_of": ["T2w", "ADC", "DWI_highb"] },
        "brain": { "any_of": ["T1", "T1c", "T2", "FLAIR"] }
      },
      "goal_template": "Task: short_superres. Requested workflow type: super_resolution. Domain: {domain}. Case ID: {case_id}. Case root: {case_root}. Execute super-resolution (NIfTI-only input) and save resampled outputs.",
      "success_criteria": {
        "all": [
          { "type": "tool_success", "tool": "resample_image" }
        ]
      },
      "required_artifacts": [
        { "id": "resampled_nifti", "tool": "resample_image", "data_key": "resampled_nifti", "must_exist": true }
      ],
      "required_stage_success": ["resample_image"],
      "invariants": [
        { "id": "resampled_exists", "type": "path_exists", "tool": "resample_image", "data_key": "resampled_nifti" },
        { "id": "resampled_non_empty", "type": "nifti_nonempty", "tool": "resample_image", "data_key": "resampled_nifti" }
      ],
      "fault_profiles": {
        "token_mutation": {
          "enabled": true,
          "token_pairs": [
            ["@runtime.case_state_path", "@state.path"],
            ["@seq.T2w", "@seq.T2"],
            ["@case.input", "@case.root"]
          ]
        },
        "path_mutation": {
          "enabled": true,
          "modes": ["in_root_semantic", "missing", "scope_escape"]
        },
        "argument_omission": {
          "enabled": true,
          "omit_keys": ["input_nifti"]
        },
        "semantic_swap": {
          "enabled": false
        },
        "space_mismatch": {
          "enabled": true,
          "space_keys": ["target_spacing"],
          "mutate_interpolation": true
        },
        "missing_modality": {
          "enabled": true
        },
        "scope_violation": {
          "enabled": true
        }
      }
    },
    "medium_register_prostate": {
      "domain": ["prostate"],
      "toolchain": "short",
      "request_type": "register",
      "required_modalities": {
        "prostate": { "all_of": ["T2w"], "any_of": ["ADC", "DWI_highb"] }
      },
      "goal_template": "Task: medium_register_prostate. Requested workflow type: register. Domain: {domain}. Case ID: {case_id}. Run short register chain identify->register only (ADC->T2w and/or DWI->T2w). Case root: {case_root}.",
      "notoken_input_aliases": {
        "prostate": ["t2w_nifti", "adc_nifti", "dwi_highb_nifti"]
      },
      "success_criteria": {
        "all": [
          { "type": "tool_success", "tool": "register_to_reference" }
        ]
      },
      "required_artifacts": [
        { "id": "registration_resampled", "tool": "register_to_reference", "data_key": "resampled_path", "must_exist": true },
        { "id": "registration_transform", "tool": "register_to_reference", "data_key": "transform_path", "must_exist": true }
      ],
      "required_stage_success": ["identify_sequences", "register_to_reference"],
      "invariants": [
        { "id": "resampled_exists", "type": "path_exists", "tool": "register_to_reference", "data_key": "resampled_path" },
        { "id": "resampled_non_empty", "type": "nifti_nonempty", "tool": "register_to_reference", "data_key": "resampled_path" }
      ],
      "fault_profiles": {
        "token_mutation": {
          "enabled": true,
          "token_pairs": [
            ["@runtime.case_state_path", "@state.path"],
            ["@seq.T2w", "@seq.T2"],
            ["@case.input", "@case.root"]
          ]
        },
        "path_mutation": {
          "enabled": true,
          "modes": ["in_root_semantic", "missing", "scope_escape"]
        },
        "argument_omission": {
          "enabled": true,
          "omit_keys": ["fixed", "moving"]
        },
        "semantic_swap": {
          "enabled": true,
          "swap_pairs": [["fixed", "moving"]],
          "min_impact": 95
        },
        "space_mismatch": {
          "enabled": true,
          "mutate_interpolation": true
        },
        "missing_modality": {
          "enabled": true
        },
        "scope_violation": {
          "enabled": true
        }
      }
    },
